# ── Spring Boot / Render Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# On Render, set these in the Environment tab of your Web Service.

# Server port (Render sets this automatically — do not override on Render)
PORT=5000

# MongoDB Atlas connection string
# Local:  mongodb://localhost:27017/compliance_platform
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/compliance_platform?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/compliance_platform

# JWT signing secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# CORS — comma-separated list of allowed frontend origins
# Local dev:   http://localhost:3000
# Production:  http://localhost:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
